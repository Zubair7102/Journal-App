# ==========================================
# Journal App - Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==========================================

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- MongoDB ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=YourApp

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars

# --- Mail ---
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Weather API ---
WEATHER_API_KEY=your-openweathermap-api-key

# --- Google OAuth Redirect (optional) ---
# GOOGLE_OAUTH_FRONTEND_REDIRECT_URI=http://localhost:3000/oauth/callback
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8081/auth/google/callback
