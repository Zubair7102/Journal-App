{
  "info": {
    "_postman_id": "journal-app-collection",
    "name": "Journal App API",
    "description": "Complete API collection for Journal App (Spring Boot).\n\n**Setup**\n1. Import this collection and `Journal-App.postman_environment.json` (optional).\n2. Set `baseUrl` to `http://localhost:8081` (dev profile).\n3. Run requests in order within each folder, or use **Run Collection**.\n\n**Auth**\n- Public endpoints need no token.\n- After **Login** or **Signup + Login**, the JWT is saved to `{{token}}` automatically.\n- Admin endpoints need `{{adminToken}}` from **Admin Login**.\n\n**First admin user**\n`POST /admin/create-admin-user` requires an existing ADMIN. Bootstrap options:\n- Promote a user in MongoDB: `roles: [\"USER\", \"ADMIN\"]`\n- Or run **Create Admin User** after logging in as an existing admin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "journalId", "value": "" },
    { "key": "userName", "value": "demo_user" },
    { "key": "password", "value": "DemoPass123!" },
    { "key": "adminUserName", "value": "demo_admin" },
    { "key": "adminPassword", "value": "AdminPass123!" },
    { "key": "cityName", "value": "London" }
  ],
  "item": [
    {
      "name": "Public",
      "description": "No authentication required",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/public/health-check"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body is OK', () => pm.expect(pm.response.text()).to.eql('OK'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{userName}}\",\n  \"password\": \"{{password}}\",\n  \"email\": \"{{userName}}@example.com\"\n}"
            },
            "url": "{{baseUrl}}/public/signup"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Created or conflict', () => {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{userName}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/public/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "const jwt = pm.response.text();",
                  "pm.collectionVariables.set('token', jwt);",
                  "pm.test('JWT saved', () => pm.expect(jwt.length).to.be.above(20));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login - Wrong Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{userName}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": "{{baseUrl}}/public/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Google OAuth",
      "description": "Requires GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET in .env",
      "item": [
        {
          "name": "Get Google Auth URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/google/url"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 503', () => {",
                  "  pm.expect([200, 503]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Has url', () => pm.expect(body.url).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Journal",
      "description": "Requires Bearer token (run Login first)",
      "item": [
        {
          "name": "Create Journal Entry",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Journal Entry\",\n  \"content\": \"Today was a great day for learning Spring Boot!\"\n}"
            },
            "url": "{{baseUrl}}/journal"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('journalId', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Journal Entries",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/journal"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 404', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Journal Entry By ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/journal/id/{{journalId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Journal Entry",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"content\": \"Updated content for this entry.\"\n}"
            },
            "url": "{{baseUrl}}/journal/id/{{journalId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Journal Entry",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/journal/id/{{journalId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 204 or 404', () => pm.expect([204, 404]).to.include(pm.response.code));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Journals - No Token (expect 403)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/journal"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Forbidden without token', () => pm.response.to.have.status(403));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User",
      "description": "Requires Bearer token",
      "item": [
        {
          "name": "Weather Greeting",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/greet?cityName={{cityName}}",
              "host": ["{{baseUrl}}"],
              "path": ["user", "greet"],
              "query": [{ "key": "cityName", "value": "{{cityName}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 404', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{userName}}_updated\",\n  \"password\": \"NewPass123!\"\n}"
            },
            "url": "{{baseUrl}}/user"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/user"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Requires ADMIN role. Run Admin Login after bootstrapping an admin user.",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{adminUserName}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/public/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login OK', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('adminToken', pm.response.text());"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Admin User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"new_admin_user\",\n  \"password\": \"AdminPass123!\",\n  \"email\": \"newadmin@example.com\"\n}"
            },
            "url": "{{baseUrl}}/admin/create-admin-user"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/all-users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Journals",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/all-journals"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Clear App Cache",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/clear-app-cache"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Users - Regular User (expect 403)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/all-users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Forbidden for non-admin', () => pm.response.to.have.status(403));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Swagger",
      "item": [
        {
          "name": "OpenAPI Docs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api-docs"
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/swagger-ui.html"
          }
        }
      ]
    }
  ]
}
